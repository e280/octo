{
	"name": "@e280/octo",
	"version": "0.1.0",
	"description": "🐙 tiny command orchestrator",
	"license": "MIT",
	"author": "Chase Moskal <chasemoskal@gmail.com>",
	"type": "module",
	"sideEffects": false,
	"files": [
		"x",
		"s"
	],
	"bin": {
		"octo": "./x/octo.js",
		"octo-parallel": "./x/octo-parallel.js",
		"octo-sequence": "./x/octo-sequence.js",
		"octo-p": "./x/octo-parallel.js",
		"octo-s": "./x/octo-sequence.js"
	},
	"scripts": {
		"build": "rm -rf x && mkdir x && tsc",
		"dev": "tsc -w & node --watch x/test.js & wait",
		"test": "node x/test.js",
		"octo": "node x/octo.js",
		"ui": "node x/octo.js 'cat package.json' 'npm run octo -- --help' 'npm test' 'sleep 2; echo hello' 'sleep 3; exit 1'",
		"count": "find s -path '*/_archive' -prune -o -name '*.ts' -exec wc -l {} +"
	},
	"dependencies": {
		"@benev/argv": "^0.3.14",
		"@e280/sten": "^0.1.1",
		"@e280/strata": "^0.3.1",
		"@e280/stz": "^0.2.26",
		"shell-quote": "^1.8.3",
		"string-width": "^8.2.0"
	},
	"devDependencies": {
		"@e280/science": "^0.1.8",
		"@types/node": "^25.5.0",
		"@types/shell-quote": "^1.7.5",
		"typescript": "^6.0.2"
	},
	"keywords": [
		"octo",
		"tui",
		"multiplexer",
		"orchestrator",
		"watch"
	],
	"homepage": "https://github.com/e280/octo#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/e280/octo.git"
	},
	"bugs": {
		"url": "https://github.com/e280/octo/issues"
	}
}
